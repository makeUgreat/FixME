{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/pr_harness.js\"",
            "timeout": 900,
            "statusMessage": "Running PR harness"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/mark_dirty.js\"",
            "timeout": 30,
            "statusMessage": "Marking repository dirty for checks"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/stop_check.js\"",
            "timeout": 600,
            "statusMessage": "Running repository checks"
          }
        ]
      }
    ]
  }
}
